-- 1. DATABASE SCHEMA SETUP
CREATE TABLE Student (
    SID INT PRIMARY KEY,
    Name VARCHAR(50),
    Branch VARCHAR(50),
    Year INT
);

CREATE TABLE Course (
    CID INT PRIMARY KEY,
    CName VARCHAR(50)
);

CREATE TABLE Enrollment (
    SID INT,
    CID INT,
    Marks INT,
    PRIMARY KEY (SID, CID),
    FOREIGN KEY (SID) REFERENCES Student(SID),
    FOREIGN KEY (CID) REFERENCES Course(CID)
);

