-- 3. SPECIFIC QUERIES
-- a) Display all students from "Computer" branch
SELECT * FROM Student WHERE Branch = 'Computer';

-- b) Find average marks of each course
SELECT CID, AVG(Marks) AS Average_Marks FROM Enrollment GROUP BY CID;

-- c) List students who scored more than 75
SELECT Student.Name, Enrollment.Marks 
FROM Student 
JOIN Enrollment ON Student.SID = Enrollment.SID 
WHERE Enrollment.Marks > 75;

-- d) Perform INNER JOIN on Student and Enrollment
SELECT Student.SID, Student.Name, Enrollment.CID, Enrollment.Marks
FROM Student
INNER JOIN Enrollment ON Student.SID = Enrollment.SID;
