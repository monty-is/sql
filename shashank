-- 3. QUERIES
-- a) Display all books issued (shows Titles and Member names)
SELECT B.Title, M.Name, I.IssueDate 
FROM Book B
JOIN Issue I ON B.BID = I.BID
JOIN Member M ON I.MID = M.MID;

-- b) Find members who have not returned books
-- (Checks where ReturnDate is NULL)
SELECT DISTINCT M.Name 
FROM Member M
JOIN Issue I ON M.MID = I.MID
WHERE I.ReturnDate IS NULL;

-- c) Count total books
SELECT COUNT(*) AS Total_Books FROM Book;

-- d) Create a VIEW for issued books
CREATE VIEW IssuedBooksView AS
SELECT B.BID, B.Title, M.Name AS MemberName, I.IssueDate, I.ReturnDate
FROM Book B
JOIN Issue I ON B.BID = I.BID
JOIN Member M ON I.MID = M.MID;

-- To see the view:
SELECT * FROM IssuedBooksView;
