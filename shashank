-- 1. DATABASE SCHEMA SETUP
CREATE TABLE Book (
    BID INT PRIMARY KEY,
    Title VARCHAR(100),
    Author VARCHAR(100),
    Price DECIMAL(10, 2)
);

CREATE TABLE Member (
    MID INT PRIMARY KEY,
    Name VARCHAR(100)
);

CREATE TABLE Issue (
    BID INT,
    MID INT,
    IssueDate DATE,
    ReturnDate DATE, -- If NULL, the book is not yet returned
    FOREIGN KEY (BID) REFERENCES Book(BID),
    FOREIGN KEY (MID) REFERENCES Member(MID)
);

