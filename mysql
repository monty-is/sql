-- 1. DATABASE CREATION
CREATE DATABASE HospitalManagement;
USE HospitalManagement;

-- 2. TABLES CREATION
-- Patient Table
CREATE TABLE Patient (
    PID INT PRIMARY KEY,
    Name VARCHAR(100),
    Disease VARCHAR(100)
);

-- Doctor Table
CREATE TABLE Doctor (
    DID INT PRIMARY KEY,
    Name VARCHAR(100),
    Specialization VARCHAR(100)
);

-- Appointment Table (Links PID and DID)
CREATE TABLE Appointment (
    PID INT,
    DID INT,
    Date DATE,
    FOREIGN KEY (PID) REFERENCES Patient(PID),
    FOREIGN KEY (DID) REFERENCES Doctor(DID)
);

