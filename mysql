-- 4. QUERIES SOLUTIONS

-- a) Display patient and doctor details
SELECT p.Name AS Patient_Name, d.Name AS Doctor_Name, d.Specialization
FROM Appointment a
JOIN Patient p ON a.PID = p.PID
JOIN Doctor d ON a.DID = d.DID;

-- b) Find patients who have no appointments
SELECT Name FROM Patient 
WHERE PID NOT IN (SELECT PID FROM Appointment);

-- c) Count total doctors
SELECT COUNT(*) AS Total_Doctors FROM Doctor;

-- d) Create a VIEW for appointment details
CREATE VIEW Appointment_Details_View AS
SELECT p.Name AS Patient_Name, d.Name AS Doctor_Name, a.Date
FROM Appointment a
JOIN Patient p ON a.PID = p.PID
JOIN Doctor d ON a.DID = d.DID;

